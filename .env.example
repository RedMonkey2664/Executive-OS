# Copy this file to .env and fill in real values. Never commit .env.

# ─────────────────────────────────────────────────────────────────────────────
# PRIMARY DATABASE — Amazon Aurora PostgreSQL (REQUIRED)
# All application data (datasets, briefs, decisions, eval results) lives here,
# accessed only via Vercel server functions (src/lib/db). Use the Aurora cluster
# (or RDS Proxy) endpoint as a standard libpq connection string, e.g.:
#   postgresql://USER:PASSWORD@your-cluster.cluster-xxxx.us-east-1.rds.amazonaws.com:5432/postgres
DATABASE_URL=
# Set PGSSL=disable ONLY for a local non-TLS Postgres. Aurora requires TLS (default on).
# PGSSL=
# PG_POOL_MAX=5

# AI provider — Google Gemini (server-side only; never expose to the browser).
# Get a FREE key from Google AI Studio: https://aistudio.google.com/apikey
# (no credit card needed). It starts with "AIza...". Set it here locally AND in
# your Vercel project's Environment Variables. This name is NOT reserved by
# Vercel/Lambda, so it works the same in both places.
GEMINI_API_KEY=
# Optional: pin the lead free-tier model, or cap output tokens.
# Leave GEMINI_MODEL unset to use the quota-friendly default chain
# (gemini-2.5-flash-lite -> gemini-2.0-flash-lite -> gemini-2.0-flash).
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_MAX_TOKENS=4096

# LLM cost / free-tier-quota controls (all optional; sensible defaults if unset).
# LLM_DAILY_CALL_BUDGET caps live calls per day so the free quota can't be burned
# in one sitting (defaults to 250; lower it to be even more conservative).
LLM_DAILY_CALL_BUDGET=
LLM_CACHE_TTL_MS=

# LLM eval harness knobs (optional)
EVAL_MIN_PASS_RATE=1.0
